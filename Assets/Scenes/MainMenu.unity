  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\r\nSometimes I like to imagine...\r\n\r\nImagine, you open your eyes
    after a long nap, and before you is a completely unfamiliar world, with nothing
    in your hands, what would you do?\r\n\r\nAt first, you might panic. You might
    try to make sense of it, to clear your vision...\r\nBut eventually... you will
    have to take a step forward, right?\r\n\r\nThe first steps might be slow and
    uncertain. \r\nThat's alright.\r\n\r\nBefore long, you\u2019ll find your footing.\r\n\r\nYou
    intend to head toward this direction, you don't know why, just feel like it.
    There might be something awaiting for you there.\n\nAnyhow, you take a step.\nYour
    exploration begins."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 5e61686ba236ff04b8632d6a26736acd, type: 2}
  m_sharedMaterial: {fileID: 2509212030381675100, guid: 5e61686ba236ff04b8632d6a26736acd, type: 2}
