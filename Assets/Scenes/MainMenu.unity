    m_PersistentCalls:
      m_Calls: []
  m_text: "\r\n<b>CREDITS:</b>\r\n\r\n - Hugest credit: This game is heavily influenced
    by Arknights, a free-to-play tactical RPG/tower defense mobile game developed
    by Hypergryph.\r\n\r\n - Assets:\r\n\r\n   + The majority of the game's assets
    (character sprites) were taken from Arknight PRTS Wiki.\r\n\r\n   + The in-game
    soundtracks and majority of the SFXs are by Arknights - MSR.\r\n\r\n   + My friend
    who helped with the Mint Fumo artwork (it's peak).\r\n\r\n   + Some images were
    taken from The Noun Project.\r\n\r\n   + Other assets I drew myself using Adobe
    Photoshop.\r\n"
