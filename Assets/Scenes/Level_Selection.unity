  skillType: 2
  skillName: 59
  skillNameText: '''Ice Age'''
  skillDescription: Enemies have <color=red>+50% max HP</color>. Upon spawning, their
    HP is halved and they are frozen for <color=#ff9717>40 seconds</color>, but have
    <color=yellow>+70 DEF</color>, <color=#00ffff>+25 RES</color> and <color=green>recovers
    2% max HP every second</color> throughout the duration.
  favorText: 
  skillDescriptionInShort: Enemies have increased HP, but spawned with 50% HP and
    frozen for 40 seconds, during which they have increased DEF and RES, and regenerates
    HP until the freeze is lost.
  mutuallyExclusiveSkills: 
  Overlay: {fileID: 0}
