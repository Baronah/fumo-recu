  m_Script: {fileID: 11500000, guid: 2f62c434b7aa76144b66a3c1597b44b1, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  OnSelectSFX: {fileID: 0}
  skillType: 1
  skillName: 46
  skillNameText: '''Beyond the Night'''
  skillDescription: Upon 'Juggernaut' activation, <color=yellow>removes all aggro</color>
    from enemies to self. While 'Juggernaut' is active, <color=#5b7ccf>ATK becomes
    0</color>, but renders self to become <color=#b1b1b1>'Invisible'</color> throughout
    the duration and grants <color=#00ffbf>increased MSPD</color>.
  favorText: "Deep inside her base, in the left corner, is a ladder leads up to the
    roof. Up there, the air is fresh and the sun feels nice, and when night falls,
    as the stars shine bright, it reveals a breathtaking scenery. Beautiful, calm,
    and soothing...\\nAstronomy might not be her field of study, but you don\u2019t
    need to be an expert to lose yourself among the stars."
  skillDescriptionInShort: '''Juggernaut'' now grants stealth and increased MSPD,
    but sets your ATK to 0.'
  mutuallyExclusiveSkills: 1500000016000000170000001800000029000000
  Overlay: {fileID: 0}
