  m_Name: 
  m_EditorClassIdentifier: 
  OnSelectSFX: {fileID: 0}
  skillType: 1
  skillName: 46
  skillNameText: Juggernaut - 'Beyond the Night'
  skillDescription: Upon 'Juggernaut' activation, removes all aggro from enemies
    to self. While 'Juggernaut' is active, ATK becomes 0, but renders self to become
    invisible throughout the duration and grants increased MSPD.
  favorText: "Deep inside her base, in the left corner, is a ladder leads up to the
    roof. The air above is fresh, and when night falls, as the stars shine bright,
    there reveals a breathtaking scenery. Beautiful, calm, and soothing...\\nAstronomy
    might not be her field of study, but you don\u2019t need to be an expert to lose
    yourself among the stars."
  skillDescriptionInShort: 
  mutuallyExclusiveSkills: 1500000016000000170000001800000029000000
  Overlay: {fileID: 0}
