  m_Name: 
  m_EditorClassIdentifier: 
  OnSelectSFX: {fileID: 0}
  skillType: 1
  skillName: 24
  skillNameText: Aftershock
  skillDescription: While 'Juggernaut' is active, damage taken is stored. After 'Juggernaut'
    ends or upon swapping it's active, deals <color=#ff4545>physical damage</color>
    equal to <color=#b1b1b1>20% max HP + 80% stored damage</color> to all nearby
    enemies and <color=#5b7ccf>'slows'</color> them briefly.
  favorText: This is gonna hurt a little.
  skillDescriptionInShort: '''Juggernaut'' stores a portion of damage taken during
    the duration, and releases it as physical damage to nearby enemies when skill
    ends or upon swapping.'
  mutuallyExclusiveSkills: 150000001600000017000000290000002e000000
  Overlay: {fileID: 0}
