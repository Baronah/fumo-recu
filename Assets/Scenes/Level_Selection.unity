  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: '<color=#79FFE1><b>Mint Fumo</b></color> is, indeed, the fumo version of
    <color=#79FFE1>Mint Arknights</color>. It is the most important resource in this
    universe.


    To collect <color=#79FFE1><b>Mint Fumo</b></color>, you simply
    need to complete levels. A single level can award up to <color=#79FFE1><b>2 Mint
    Fumos</b></color>:


    + One <color=#79FFE1><b>Mint Fumo</b></color> is awarded
    upon completing a level for the first time. Any exploration mode counts for this,
    but <color=yellow>the fumo can only be claimed once</color>.


    + Clearing
    a <color=red>Challenge Mode</color> of a level for the first time also awards
    a <color=#79FFE1><b>Mint Fumo</b></color>. Similarly, you can do it in any exploration
    mode, so fit yourself.


    ----------------------------------------------------------------------


    As
    for what they do, you can spend them to unlock research categories.


    But,
    well, even after you unlock all of that, you probably will still be left with
    some.

    In that case, just keep the rest.

    They are <color=#79FFE1><b>Mint
    Fumos</b></color>, after all. Who doesn''t like <color=#79FFE1><b>Mint Fumo</b></color>?


'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 5e61686ba236ff04b8632d6a26736acd, type: 2}
  m_sharedMaterial: {fileID: 2509212030381675100, guid: 5e61686ba236ff04b8632d6a26736acd, type: 2}
