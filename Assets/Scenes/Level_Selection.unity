  m_Name: 
  m_EditorClassIdentifier: 
  OnSelectSFX: {fileID: 0}
  skillType: 0
  skillName: 61
  skillNameText: A nice-looking piece of rock
  skillDescription: Gains a 5.2% buff in <color=green>HP</color>, <color=#ff4545>ATK</color>
    and <color=#00ffbf>MSPD</color>. Upon entering the field, grants your character
    <color=#ff00ff>a random INVENTIO upgrade</color>. Upgrades granted this way are
    not affected by mutual exclusives, but will not overlap with chosen ones.
  favorText: Even if it is an unassuming piece of ore that is covered in dirt, if
    she gives you a present, please accept it. It must be something she likes a lot
    and wants to share with you anyway.
  skillDescriptionInShort: Gains increased HP, ATK and MSPD. Upon entering the field,
    grants your character a random upgrade.
  mutuallyExclusiveSkills: 
  Overlay: {fileID: 0}
