  m_Name: 
  m_EditorClassIdentifier: 
  OnSelectSFX: {fileID: 0}
  skillType: 1
  skillName: 16
  skillNameText: Cryopump
  skillDescription: '''Zeropoint Burst'' <color=#00ffff>marks</color> all enemies
    hit. After a 2 seconds delay, marked enemies create an extra ''Zeropoint Burst''
    around them, whose maximum freeze duration equals to the current freeze duration
    of the enemy starting it. Marks <color=yellow>persist across swaps</color>, but
    can not appear on the same enemy twice per usage.'
  favorText: '"Please calm down a little!"'
  skillDescriptionInShort: '''Zeropoint Burst'' now spreads the freeze to enemies
    around the targets.'
  mutuallyExclusiveSkills: 110000001200000035000000
  Overlay: {fileID: 0}
