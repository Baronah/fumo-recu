  skillType: 2
  skillName: 62
  skillNameText: '''Adaption'''
  skillDescription: Enemies <color=yellow>start with 0 DEF and RES</color>, but gain
    <color=green>max HP</color> equals to their base DEF and RES. Upon receiving
    <color=red>physical damage</color>, they gain <color=red>+5 DEF</color>. Upon
    receiving <color=#ff00ff>magical damage</color>, they gain <color=#ff00ff>+3
    RES</color>. Both can stack up to 30 times.
  favorText: 
  skillDescriptionInShort: Enemies have 0 DEF and RES, but gain increased DEF/RES
    upon taking physical/magical damage.
  mutuallyExclusiveSkills: 
  Overlay: {fileID: 0}
