  m_Script: {fileID: 11500000, guid: 2f62c434b7aa76144b66a3c1597b44b1, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  OnSelectSFX: {fileID: 0}
  skillType: 0
  skillName: 60
  skillNameText: Neatly tied knot
  skillDescription: The first time you cast special or ultimate skill of a character,
    forms a vow with it. Afterwards, that skill has <color=#ff9717>reduced cool-down</color>,
    <color=#00ff00>enhanced effects</color> and grants you bonus attributes, <color=#5b7ccf>but
    the remaining skill can no longer be used</color>.
  favorText: '"Oh, I have many threads here. Pick any color you like, then, let''s
    both tie them around our finger, just like this... Cute, isn''t it? We just made
    a symbol of promise, so don''t forget it! Hehe..."'
  skillDescriptionInShort: Casting a special or ultimate skill for the first time
    forms a vow with it, enhancing its effect but prevents the other skill from being
    used.
  mutuallyExclusiveSkills: 
  Overlay: {fileID: 0}
