  m_Name: 
  m_EditorClassIdentifier: 
  OnSelectSFX: {fileID: 0}
  skillType: 2
  skillName: 56
  skillNameText: '''Statis'''
  skillDescription: 'All units that haven''t moved for more than <color=#ff9717>5
    seconds</color> enters ''statis'': Has <color=#5b7ccf>-50% ATK</color>, but <color=green>regenerates
    4% HP</color> every second and <color=yellow>HP can not fall below 1</color>.
    Any movement made breaks this state.\n\n<i>If <color=#ff00ff>''Attention-holding
    Device''</color> is selected, required time on you is reduced to <color=#ff9717>3
    seconds</color>.</i>'
  favorText: 
  skillDescriptionInShort: 'All units that haven''t moved for a while enters ''statis'':
    Has reduced ATK, but regenerates HP and HP can not fall below 1. Any movement
    made breaks this state.'
  mutuallyExclusiveSkills: 
  Overlay: {fileID: 0}
