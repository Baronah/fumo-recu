  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "A private place filled with books, crafts, ideas, theories, and a bunch
    of everything else. \r\nEach is a mystery awaiting to be figured out.\n\nShe
    comes here whenever new idea sparks,\r\nTo implement. To experiment. To verify.
    Or simply, to write it down.\r\n\r\nShe also uses this place to store valuable
    items to her, such as samples for experiment, books, novel-looking ores, or just
    thing she really likes.\r\n\r\nIn short, it's a little of everything!\r\nWelcome
    to Mint's research.\r\n\r\nFeel free to look around, and if there's something
    that you need here, you may bring it along.\r\nThough, remember to return them
    when you're finished. \r\n\r\nYou are welcomed to this place anytime! \r\n\r\n<color=#b1b1b1>Oh,
    and also, this is her secret base. \r\nShe loves it here more than anywhere.
    \r\nDon't tell anyone else about it, okay?</color>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 5e61686ba236ff04b8632d6a26736acd, type: 2}
  m_sharedMaterial: {fileID: 2509212030381675100, guid: 5e61686ba236ff04b8632d6a26736acd, type: 2}
