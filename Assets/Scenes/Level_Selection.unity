  m_EditorClassIdentifier: 
  OnSelectSFX: {fileID: 0}
  skillType: 2
  skillName: 54
  skillNameText: '''Hyper Acceleration'''
  skillDescription: All units gain <color=#00ffbf>increased MSPD</color> when continuously
    moving toward a direction, up to <color=#00ffbf>+200% MSPD</color>. Changing
    direction will <color=yellow>remove the MSPD buff</color> and inflicts <color=#5b7ccf>a
    decaying 'Slow'</color> based on the removed acceleration.\n\n<i>If any <color=#ff00ff>'Arts
    Unit'</color> is selected, you accelerate <color=yellow>50% faster</color>.</i>
  favorText: 
  skillDescriptionInShort: All units gain increased MSPD when continuously moving
    toward a direction, up to +200% MSPD. Changing direction will remove the buff
    and inflicts a decaying 'Slow' based on the previous acceleration.
  mutuallyExclusiveSkills: 
  Overlay: {fileID: 0}
